==============================
CORE API KEYS
==============================
HuggingFace (required)
Used for: pyannote diarization + IndicConformer + model downloads

HF_TOKEN=your_huggingface_token_here

==============================
ZOHO WORKDRIVE (if pulling audio from cloud)
==============================

ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_WORKDRIVE_FOLDER_ID=your_folder_id # folder containing audio files
